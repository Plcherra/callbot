# Callbot environment template
# Copy to .env.local in project root
# Dev: .env.local | Production: .env or .env.local on VPS
#
# Canonical source: deploy/env/.env.example (use that for deploy/VPS setup)
# Python backend loads from project root.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === Stripe ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_PAYG=price_...
STRIPE_PRICE_DEV_TEST=price_...
STRIPE_PRICE_ID=price_...

# === Telnyx ===
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=
TELNYX_WEBHOOK_BASE_URL=https://echodesk.us
# TELNYX_SKIP_VERIFY=1  # Set when Cloudflare/proxy strips verification headers
TELNYX_CONNECTION_ID=

# === Voice AI (backend) ===
DEEPGRAM_API_KEY=
GROK_API_KEY=
# TTS_PROVIDER= google
TTS_PROVIDER=google

# Google Cloud TTS when TTS_PROVIDER=google (ADC or GOOGLE_APPLICATION_CREDENTIALS)
# GOOGLE_TTS_DEFAULT_VOICE_NAME=en-US-Neural2-C
# GOOGLE_TTS_BACKUP_VOICE_NAME=en-US-Neural2-A
# GOOGLE_TTS_SPEAKING_RATE=1.22
# GOOGLE_TTS_VOICE_ALLOWLIST=
# TTS_CACHE_BACKEND=none
# TTS_MAX_CHARS_PER_UTTERANCE=800
# TTS_MAX_REQUESTS_PER_CALL=30

# === Voice pipeline auth ===
VOICE_SERVER_API_KEY=optional_secret

# === App URL (redirects, OAuth) ===
APP_URL=https://echodesk.us

# === Google OAuth ===
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=https://echodesk.us/api/google/callback

# === Cron ===
CRON_SECRET=your_cron_secret

# === FCM push ===
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
