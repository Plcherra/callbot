# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe (STRIPE_SECRET_KEY can be a restricted key, e.g. webhook-ai — see docs/STRIPE_PERMISSIONS.md)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_... or your restricted key
STRIPE_WEBHOOK_SECRET=whsec_...
# Subscription plan price IDs (recurring monthly)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...
# DEV test ($1/mo for testing)
STRIPE_PRICE_DEV_TEST=price_...
# Per-minute plan base price IDs (recurring monthly; usage billed separately)
STRIPE_PRICE_PER_MINUTE_1=price_...
STRIPE_PRICE_PER_MINUTE_2=price_...
STRIPE_PRICE_PER_MINUTE_3=price_...
# Legacy: single price (treated as Starter if STRIPE_PRICE_STARTER not set)
STRIPE_PRICE_ID=price_...
# Optional: from Stripe Payment Links → Buy button → Copy code (buy-button-id)
NEXT_PUBLIC_STRIPE_BUY_BUTTON_ID=

# Twilio (self-hosted voice AI)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Public URL for webhooks (must be reachable by Twilio). For local: use ngrok or Cloudflare Tunnel.
TWILIO_WEBHOOK_BASE_URL=https://echodesk.us
# Voice mode: "gather" = TwiML Gather/Say (no extra server), "streams" = Media Streams to VOICE_SERVER_WS_URL
TWILIO_VOICE_MODE=gather
# For streams mode: WebSocket URL of your voice server (e.g. wss://echodesk.us/ws)
VOICE_SERVER_WS_URL=wss://echodesk.us/ws
VOICE_SERVER_API_KEY=optional_secret_for_prompt_api

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: test call number shown in onboarding when user has no receptionist yet
# NEXT_PUBLIC_TEST_CALL_NUMBER=+15551234567
# Required for cron endpoints (billing, usage, cost-backfill)
CRON_SECRET=your_cron_secret

# Analytics (optional, for beta/launch tracking)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Marketing (optional)
NEXT_PUBLIC_DEMO_VIDEO_ID=
