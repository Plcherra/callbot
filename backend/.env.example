# Backend (Python voice) environment
# When co-located with Next.js, most vars come from project root .env/.env.local.
# This file lists backend-specific vars for standalone backend deploys.
#
# For full app (Next.js + backend on same host), copy deploy/env/.env.example
# to project root and fill in values. Backend loads from project root .env.

# === Supabase ===
# Prefer NEXT_PUBLIC_SUPABASE_URL (shared). SUPABASE_URL is deprecated alias.
# NEXT_PUBLIC_SUPABASE_ANON_KEY required for /api/mobile auth (JWT validation). Same as Flutter SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Telnyx ===
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=
TELNYX_WEBHOOK_BASE_URL=https://your-voice-backend.example.com
# TELNYX_SKIP_VERIFY=  # Set 1 when proxy strips headers (e.g. Cloudflare Tunnel); use TELNYX_ALLOWED_IPS for defense-in-depth
# TELNYX_ALLOWED_IPS=  # Optional: comma-separated IPs when TELNYX_SKIP_VERIFY; empty = no allowlist

# === Voice AI ===
DEEPGRAM_API_KEY=
GROK_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=CwhRBWXzGAHq8TQ4Fs17

# === Voice server ===
VOICE_SERVER_API_KEY=
# VOICE_PROMPT_BASE_URL=  # Optional; default http://127.0.0.1:PORT

# === App API (Next.js) for FCM push, quota checks ===
APP_API_BASE_URL=https://your-app.example.com
INTERNAL_API_KEY=
# next_public_app_url: backend falls back to this when APP_API_BASE_URL unset

# === Cron (optional) ===
# CRON_SECRET=  # Same as Next.js; for backend→Next.js cron proxy

# === Firebase (optional) ===
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# === Google Calendar ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=
# GOOGLE_OAUTH_STATE_SECRET=  # Optional: HMAC secret for OAuth state (defaults to SUPABASE_SERVICE_ROLE_KEY)

# === App ===
PORT=8000
