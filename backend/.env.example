FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=

# App
PORT=8000
