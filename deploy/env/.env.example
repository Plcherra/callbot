# Callbot environment template (canonical for deploy)
# Copy to project root as .env or .env.local
# Production: .env or .env.local on VPS
#
# Architecture: Python FastAPI only. No Next.js.
# Landing page: static HTML from landing/dist

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === Stripe ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_PAYG=price_...
STRIPE_PRICE_DEV_TEST=price_...
STRIPE_PRICE_ID=price_...

# === Telnyx ===
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=
TELNYX_WEBHOOK_BASE_URL=https://echodesk.us
# TELNYX_SKIP_VERIFY=1  # Set when Cloudflare/proxy strips verification headers
# TELNYX_ALLOWED_IPS=  # Optional: comma-separated IPs when TELNYX_SKIP_VERIFY
# TELNYX_ALLOW_RECEPTIONIST_FALLBACK=0  # Never use first receptionist when DID unmatched (default). Set 1 only for debug.
TELNYX_CONNECTION_ID=

# === Voice AI (backend) ===
DEEPGRAM_API_KEY=
GROK_API_KEY=
# === Google Cloud TTS (required; ADC or GOOGLE_APPLICATION_CREDENTIALS) ===
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GOOGLE_TTS_DEFAULT_LANGUAGE_CODE=en-US
# GOOGLE_TTS_DEFAULT_VOICE_NAME=en-US-Neural2-C
# GOOGLE_TTS_BACKUP_VOICE_NAME=en-US-Neural2-A
# GOOGLE_TTS_ALLOW_PREMIUM_TIERS=false
# GOOGLE_TTS_SPEAKING_RATE=1.22
# GOOGLE_TTS_PITCH=0.0
# TTS_CACHE_BACKEND=none
# TTS_CACHE_FILESYSTEM_DIR=
# TTS_GOOGLE_MAX_RETRIES=5
# Stripe Option A: STRIPE_PRICE_STARTER, STRIPE_PRICE_GROWTH, STRIPE_PRICE_PRO (monthly)
# STRIPE_PRICE_GROWTH=

# === Voice pipeline auth ===
VOICE_SERVER_API_KEY=optional_secret

# === App URL (for redirects, OAuth, etc.) ===
APP_URL=https://echodesk.us

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OAuth callback: must match Google Cloud Console redirect URI
GOOGLE_REDIRECT_URI=https://echodesk.us/api/google/callback

# === Cron ===
CRON_SECRET=your_cron_secret

# === Mobile ===
# MOBILE_REDIRECT_SCHEME=echodesk  # Optional; default echodesk

# === FCM push ===
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# === Optional: Sentry (backend error tracking) ===
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production

# === Optional: demo/test ===
# NEXT_PUBLIC_DEMO_VIDEO_ID=  # Optional; YouTube video ID for landing page
