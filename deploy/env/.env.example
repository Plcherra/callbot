# Callbot environment template
# Copy to project root as .env or .env.local
# Dev: .env.local | Production: .env or .env.local on VPS

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === Stripe ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_PAYG=price_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_BUY_BUTTON_ID=

# === Telnyx ===
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=
TELNYX_WEBHOOK_BASE_URL=https://echodesk.us
TELNYX_CONNECTION_ID=

# === Voice AI (backend) ===
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
GROK_API_KEY=

# === Voice pipeline auth ===
VOICE_SERVER_API_KEY=optional_secret

# === Backend → Next.js internal APIs ===
APP_API_BASE_URL=https://echodesk.us
INTERNAL_API_KEY=shared_secret

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your_cron_secret

# === Server Actions (PM2/VPS - required) ===
# Generate: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# === FCM push ===
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# === Optional: Sentry, PostHog ===
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
