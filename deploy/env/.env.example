# Callbot environment template (canonical for deploy)
# Copy to project root as .env or .env.local
# Production: .env or .env.local on VPS
#
# Architecture: Python FastAPI only. No Next.js.
# Landing page: static HTML from landing/dist

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === Stripe ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_PAYG=price_...
STRIPE_PRICE_DEV_TEST=price_...
STRIPE_PRICE_ID=price_...

# === Telnyx ===
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=
TELNYX_WEBHOOK_BASE_URL=https://echodesk.us
# TELNYX_SKIP_VERIFY=1  # Set when Cloudflare/proxy strips verification headers
# TELNYX_ALLOWED_IPS=  # Optional: comma-separated IPs when TELNYX_SKIP_VERIFY
TELNYX_CONNECTION_ID=

# === Voice AI (backend) ===
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
GROK_API_KEY=

# === Voice pipeline auth ===
VOICE_SERVER_API_KEY=optional_secret

# === App URL (for redirects, OAuth, etc.) ===
APP_URL=https://echodesk.us

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# OAuth callback: must match Google Cloud Console redirect URI
GOOGLE_REDIRECT_URI=https://echodesk.us/api/google/callback

# === Cron ===
CRON_SECRET=your_cron_secret

# === Mobile ===
# MOBILE_REDIRECT_SCHEME=echodesk  # Optional; default echodesk

# === FCM push ===
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# === Optional: demo/test ===
# NEXT_PUBLIC_DEMO_VIDEO_ID=  # Optional; YouTube video ID for landing page
