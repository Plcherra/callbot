# Callbot environment template (canonical for deploy)
# Copy to project root as .env or .env.local
# Dev: .env.local | Production: .env or .env.local on VPS
#
# Both Next.js and Python backend load from project root .env/.env.local.

# === Supabase ===
# Canonical: NEXT_PUBLIC_* (shared with frontend). SUPABASE_URL is deprecated alias for backend-only deploys.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === Stripe ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_PAYG=price_...
STRIPE_PRICE_DEV_TEST=price_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_BUY_BUTTON_ID=

# === Telnyx ===
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=
TELNYX_WEBHOOK_BASE_URL=https://echodesk.us
# TELNYX_STREAM_BASE_URL=  # Optional: direct URL for media stream
# TELNYX_SKIP_VERIFY=1  # Set when Cloudflare/proxy strips verification headers
TELNYX_CONNECTION_ID=

# === Voice AI (backend) ===
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
GROK_API_KEY=

# === Voice pipeline auth ===
VOICE_SERVER_API_KEY=optional_secret
# VOICE_PROMPT_BASE_URL=  # Optional: URL for voice→Next.js prompt fetch (default: http://127.0.0.1:8000)

# === Backend → Next.js internal APIs ===
APP_API_BASE_URL=https://echodesk.us
INTERNAL_API_KEY=shared_secret

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your_cron_secret

# === Mobile ===
# MOBILE_REDIRECT_SCHEME=echodesk  # Optional; default echodesk

# === Server Actions (PM2/VPS - required) ===
# Generate: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# === FCM push ===
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# === Optional: Sentry, PostHog, demo/test ===
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_TEST_CALL_NUMBER=  # Optional; demo call number for onboarding
# NEXT_PUBLIC_DEMO_VIDEO_ID=  # Optional; YouTube video ID for landing page
