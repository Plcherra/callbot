# Production-specific overrides for echodesk.us
# Merge these with .env.example when deploying to VPS

# URLs must be public
NEXT_PUBLIC_APP_URL=https://echodesk.us
TELNYX_WEBHOOK_BASE_URL=https://echodesk.us
APP_API_BASE_URL=https://echodesk.us

# OAuth redirect
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://echodesk.us/api/google/callback

# Use production Stripe keys (pk_live_, sk_live_)
# Use production Supabase project
# Ensure TELNYX_PUBLIC_KEY or TELNYX_WEBHOOK_SECRET for webhook verification
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY must be set before npm run build
