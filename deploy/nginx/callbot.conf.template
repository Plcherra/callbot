# Callbot nginx config template
# Domain: echodesk.us (main site via Cloudflare Tunnel)
# Stream: stream.echodesk.us (Telnyx media stream - direct to VPS, DNS-only)
#
# Ports:
#   - Port 80: Cloudflare Tunnel forwards echodesk.us here (http://127.0.0.1:80)
#   - Port 443: direct HTTPS/WSS for stream.echodesk.us if you use the stream subdomain
#
# IMPORTANT:
#   - For Cloudflare Tunnel / proxied setups, DO NOT redirect origin port 80 back to HTTPS.
#   - Cloudflare handles HTTPS for echodesk.us at the edge.
#   - If `curl -I -H "Host: echodesk.us" http://127.0.0.1/` returns 301, origin config is wrong.
#
# SSL cert should include:
#   echodesk.us, www.echodesk.us, stream.echodesk.us
#
# Install:
#   sudo cp deploy/nginx/callbot.conf.template /etc/nginx/sites-available/callbot
# Enable:
#   sudo ln -sf /etc/nginx/sites-available/callbot /etc/nginx/sites-enabled/callbot

# Test + reload:
#   sudo nginx -t && sudo systemctl reload nginx
#
# IMPORTANT about LANDING_ROOT:
#   {{LANDING_ROOT}} must be replaced with a REAL absolute path on the VPS.
#   Do not leave the literal placeholder in the live nginx file.
#   Prefer a path readable by nginx/www-data, e.g. /var/www/echodesk-landing 
#   rather than a path under /home/adam unless permissions are opened correctly.
#
# Quick deploy example:
#   sudo mkdir -p /var/www/echodesk-landing
#   sudo rsync -a /home/adam/apps/callbot/landing/dist/ /var/www/echodesk-landing/
#   sed "s|{{LANDING_ROOT}}|/var/www/echodesk-landing|g" deploy/nginx/callbot.conf.template | sudo tee /etc/nginx/sites-available/callbot >/dev/null

server {
    listen 80;
    listen [::]:80;
    server_name echodesk.us www.echodesk.us;

    # WebSocket diagnostic route (before /api/)
    location = /ws-test {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    # Voice webhook
    location ^~ /api/telnyx/voice {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Voice WebSocket stream
    location ^~ /api/voice/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_connect_timeout 60s;
    }

    # Telnyx CDR
    location ^~ /api/telnyx/cdr {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Telnyx outbound
    location ^~ /api/telnyx/outbound {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # All other API routes
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Compliance pages (exact paths; avoid SPA try_files fallback to index.html)
    location = /privacy {
        alias {{LANDING_ROOT}}/privacy.html;
    }
    location = /terms {
        alias {{LANDING_ROOT}}/terms.html;
    }

    # Main landing/static site.
    # No redirect here; Cloudflare Tunnel sends HTTP to origin and handles HTTPS externally.
    # {{LANDING_ROOT}} must be replaced before deployment.
    # The resolved directory must be readable by nginx/www-data.
    location / {
        root {{LANDING_ROOT}};
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name echodesk.us www.echodesk.us;

    ssl_certificate /etc/letsencrypt/live/echodesk.us/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/echodesk.us/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # WebSocket diagnostic route (before /api/)
    location = /ws-test {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    # Voice webhook
    location ^~ /api/telnyx/voice {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Voice WebSocket stream
    location ^~ /api/voice/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_connect_timeout 60s;
    }

    # Telnyx CDR
    location ^~ /api/telnyx/cdr {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Telnyx outbound
    location ^~ /api/telnyx/outbound {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # All other API routes
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Compliance pages (exact paths; avoid SPA try_files fallback to index.html)
    location = /privacy {
        alias {{LANDING_ROOT}}/privacy.html;
    }
    location = /terms {
        alias {{LANDING_ROOT}}/terms.html;
    }

    # Static landing (served by nginx)
    # The resolved LANDING_ROOT path must exist and be readable by nginx/www-data.
    location / {
        root {{LANDING_ROOT}};
        try_files $uri $uri/ /index.html;
    }
}

# Dedicated stream.echodesk.us server block (Telnyx media - direct to VPS, DNS-only)
server {
    listen 80;
    listen [::]:80;
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name stream.echodesk.us;

    ssl_certificate /etc/letsencrypt/live/echodesk.us/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/echodesk.us/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers HIGH:!aNULL:!MD5;

    location = /ws-test {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }

    location ^~ /api/voice/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_connect_timeout 60s;
    }

    location ~ ^/(api/)?health$ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        add_header Content-Type text/plain;
        return 200 'stream endpoint';
    }
}
